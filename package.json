{
  "name": "clear",
  "version": "1.0.0",
  "description": "Api and Frontend tests",
  "main": "index.js",
  "scripts": {
    "open": "cypress open --e2e -b chrome",
    "all": "cypress run --browser chrome --headless --config chromeWebSecurity=false",
    "spec": "cypress run --browser chrome --headless --spec $npm_config_spec --config chromeWebSecurity=false",
    "prereport": "rm -rf cypress/reports",
    "report": "npm run all || true && npm run report:merge && npm run report:generate",
    "report:merge": "mochawesome-merge cypress/reports/json/*.json -o cypress/reports/report.json",
    "report:generate": "marge cypress/reports/report.json --reportDir cypress/reports --inline --reportFilename report"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@faker-js/faker": "^9.9.0",
    "@types/node": "^25.5.2",
    "cypress": "^15.13.1",
    "cypress-plugin-api": "^2.11.1",
    "mochawesome": "^7.1.4",
    "mochawesome-merge": "^5.1.1",
    "mochawesome-report-generator": "^6.3.2",
    "typescript": "^5.9.3"
  }
}
